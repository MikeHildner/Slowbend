# Copy this file to .env.deploy and fill in the real values.
# .env.deploy is git-ignored — never commit credentials.

# FTP address from the discountasp.net control panel
FTP_HOST=ftp.example.com

# FTP username
FTP_USER=username

# FTP password — EITHER put it here...
#FTP_PASSWORD=secret
# ...OR (better, avoids special-character parsing issues) name an existing
# environment variable that holds it:
FTP_PASSWORD_ENV=DAP_PW

# Folder on the server to publish into (cleared on every deploy!)
FTP_REMOTE_DIR=/slowbend

# Set to false only if the server does not support FTPS (encrypted FTP)
FTP_SECURE=true
